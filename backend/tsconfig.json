{
  "compilerOptions": {
    "target":             "ES2022",
    "module":             "NodeNext",
    "moduleResolution":   "NodeNext",
    "lib":                ["ES2022"],
    "outDir":             "./dist",
    "rootDir":            ".",
    "strict":             true,
    "esModuleInterop":    true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule":  true,
    "skipLibCheck":       true,
    "declaration":        true,
    "sourceMap":          true,
    "noUnusedLocals":     false,
    "noUnusedParameters": false
  },
  "include": ["src/**/*", "prisma/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
