# ─── Server ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:4200

# ─── Database (PostgreSQL 18 — EDB, port 5432) ───────────
DATABASE_URL="postgresql://bloomberg_user:bloomberg_pass@localhost:5432/bloomberg_tracker?schema=public"

# ─── Redis (Memurai on Windows / Redis on Linux) ─────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=300

# ─── Finnhub ─────────────────────────────────────────────
FINNHUB_API_KEY=your_finnhub_api_key_here
FINNHUB_WSS=wss://ws.finnhub.io
FINNHUB_BASE_URL=https://finnhub.io/api/v1

# ─── Alpha Vantage ───────────────────────────────────────
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query

# ─── Twelve Data ─────────────────────────────────────────
TWELVE_DATA_API_KEY=your_twelve_data_key_here
TWELVE_DATA_BASE_URL=https://api.twelvedata.com

# ─── CoinGecko ───────────────────────────────────────────
COINGECKO_API_KEY=your_coingecko_pro_key_here
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# ─── Binance ─────────────────────────────────────────────
BINANCE_WSS=wss://stream.binance.com:9443
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET=your_binance_secret

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET=your_super_secure_jwt_secret_here
JWT_EXPIRES_IN=7d

# ─── Rate Limits ─────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000
